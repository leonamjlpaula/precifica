# Template de variáveis de ambiente do Precifica
# ─────────────────────────────────────────────────────────────────────────────
# Dev e Prod apontam para o mesmo Supabase.
# Copie para .env.local e preencha com os valores do painel do Supabase.
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de dados ────────────────────────────────────────────────────────────
# Supabase → Settings → Database → Connect → Transaction Pooler (porta 6543) — usado pelo app
# ?pgbouncer=true desativa prepared statements (incompatíveis com PgBouncer em transaction mode)
# ?connection_limit=1 limita cada instância serverless a 1 conexão no pool
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Supabase → Settings → Database → Connect → Direct connection — usado pelo prisma migrate
DIRECT_URL="postgresql://postgres.xxxx:password@db.xxxx.supabase.co:5432/postgres"

# ── Supabase Auth ─────────────────────────────────────────────────────────────
# Supabase → Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SECRET_KEY="sb_secret_..."
