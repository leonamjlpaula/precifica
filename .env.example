# Template de variáveis de ambiente do Precifica
# ─────────────────────────────────────────────────────────────────────────────
# Dev:  copie para .env.local  →  aponta para Docker (PostgreSQL) + Mailhog
# Prod: configure no painel da Vercel (ou copie para .env)  →  Supabase + Resend
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de dados ────────────────────────────────────────────────────────────
# Dev:  postgresql://postgres:postgres@localhost:5432/precifica
# Prod: connection string do Supabase (Settings → Database → Connection string)
DATABASE_URL="postgresql://user:password@host:5432/precifica"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Gere um secret seguro com: openssl rand -base64 32
# Dev: qualquer string serve (ex: "dev-secret-local")
NEXTAUTH_SECRET="gere-com-openssl-rand-base64-32"
# Dev: http://localhost:3000  |  Prod: URL do deploy (ex: https://precifica-xyz.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

# ── Email ─────────────────────────────────────────────────────────────────────
# Dev — Mailhog captura os emails localmente (UI em http://localhost:8025)
# SMTP_HOST="localhost"
# SMTP_PORT="1025"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="Precifica <noreply@precifica.local>"

# Prod — Resend SMTP (domínio tothemapps.com verificado no painel do Resend)
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="resend"
SMTP_PASS="re_sua_api_key_aqui"
SMTP_FROM="Precifica <noreply@tothemapps.com>"
